<label for="searchGenre"> Sort by Genre:</label>
<InputText id="searchGenre" @bind-Value="filterGenre" />
@if (filterGenre != null)
{
	if (filterGenre != "")
	{
		filterGenre = filterGenre.ToLower();
		videogamesToDisplay = videogamesToDisplay.Where(v => v.Genre.ToLower().Contains(filterGenre)).OrderByDescending(v => v.Genre.ToLower().Contains(filterGenre)).ToList<Videogame>();

	}

}
<br />
<label for="searchESRB"> Sort by Rating:</label>

<InputRadioGroup TValue="ESRB" id="searchESRB" @bind-Value="filterESRB">
	<ul class="no-bullets">

		@foreach (var rating in ESRB_List)
		{
			<li>
				<InputRadio Value="rating" />
				@rating
			</li>

		}
	</ul>
</InputRadioGroup>
@if (filterESRB != ESRB.NULL)
{
	videogamesToDisplay = videogamesToDisplay.Where(v => v.Rating.Equals(filterESRB)).OrderByDescending(v => v.Rating.Equals(filterESRB)).ToList<Videogame>();
}


<br />
<button type="button" @onclick="ClearFilters"> Clear Filters</button>
*@
@if (Weapons == BioWeaponService.GetBioWeapons() || Weapons.Count ==BioWeaponService.GetBioWeapons().Count)
{
	<p>You are viewing all @BioWeaponService.GetBioWeapons().Count weapons!</p>
}
else
{
	<p>You are viewing @Weapons.Count weapons out of @BioWeaponService.GetBioWeapons().Count</p>
}

<table class="table">
	<thead>
		<tr>
			<th>
				Name
			</th>
			<th>
				Cost
			</th>
			<th>
				Grade
			</th>
			<th>
				Attack Type
			</th>
			<th>
				Attack Damage
			</th>
			<th>
				Attack Speed
			</th>
			<th>
				Range
			</th>
			<th>
				Description
			</th>
			<th>
				Delete Weapon
			</th>
			<th>
				Clone Weapon
			</th>
		</tr>
	</thead>
	<tbody>

		@foreach (var w in Weapons)
		{
			<AzureSQLTest.Components.Subs.WeaponDisplay Weapon="w" OnDelete="OnDeleteClick" OnClone="OnCloneClick" />
		}
	</tbody>

</table>

@code {
	//private ApplicationDbContext Context { get; set; }
	private List<BioWeapon>? Weapons;
	private BioWeapon newWeapon = new BioWeapon();

	public string? filterName;


    //private ApplicationDbContext Context { get; set; }
    private List<BioWeapon>? Weapons;
    private List<UserInfo>? UserInfo;
    public int test = 0;
    protected override void OnInitialized()
    {
        Weapons = BioWeaponService.GetBioWeapons();
        UserInfo = UserInfoService.GetUserInfos();


	private void AddWeapon()
	{
		BioWeaponService.AddBioWeapon(newWeapon);
		Weapons = BioWeaponService.GetBioWeapons();
		newWeapon = new BioWeapon();
		//editContext = new EditContext(newWeapon);
		StateHasChanged();
	}

	private void InvalidDebug(EditContext editContext)
	{
		var test = editContext;
		Console.WriteLine("Invalid form submission");
	}
	protected override void OnInitialized()
	{
		Weapons = BioWeaponService.GetBioWeapons();
	}


	public void OnDeleteClick(int id)
	{
		// Parent handles deletion and refreshes its list
		var delWeapon = BioWeaponService.GetBioWeapons().FirstOrDefault(w =>w.Id ==id);
		if (delWeapon != null)
		{
			BioWeaponService.DeleteBioWeapon(id);
			Weapons = BioWeaponService.GetBioWeapons();
		}
		StateHasChanged();
	}

	public void OnCloneClick(int id)
	{
		var cloneWeapon = BioWeaponService.GetBioWeapons().FirstOrDefault(w => w.Id == id);
		if (cloneWeapon != null)
		{
			BioWeaponService.AddBioWeapon(new BioWeapon
			{
				Weapon_Name = cloneWeapon.Weapon_Name,
				Cost = cloneWeapon.Cost,
				Grade = cloneWeapon.Grade,
				Attack_Type = cloneWeapon.Attack_Type,
				Attack_Damage = cloneWeapon.Attack_Damage,
				Attack_Speed = cloneWeapon.Attack_Speed,
				Weapon_Range = cloneWeapon.Weapon_Range,
				Weapon_Description = cloneWeapon.Weapon_Description
			});
			Weapons = BioWeaponService.GetBioWeapons();
		}
		StateHasChanged();
	}
}