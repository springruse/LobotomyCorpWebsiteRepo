@using AzureSQLTest.Data
@rendermode InteractiveServer
@inject IBioWeaponable BioWeaponService

<tr>
				<td>Name: @Weapon.Weapon_Name</td>
				<td>Cost: @Weapon.Cost</td>
				<td>Grade: @Weapon.Grade</td>
				<td>Attack type: @Weapon.Attack_Type</td>
				<td>Attack Damage: @Weapon.Attack_Damage</td>
				<td>Attack Speed: @Weapon.Attack_Speed</td>
				<td>Range: @Weapon.Weapon_Range</td>
				<td>Description: @Weapon.Weapon_Description</td>
		<button class="btn btn-danger" @onclick="HandleDelete">Delete</button>
				
			</tr>
		
@code {
	[Parameter]
	public BioWeapon Weapon { get; set; }
	[Parameter]
	public EventCallback<int> OnDelete { get; set; }
	private async Task HandleDelete()
	{
		// Prefer notifying parent; parent will call the service and update UI.
		if (OnDelete.HasDelegate)
		{
			await OnDelete.InvokeAsync(Weapon.Id);
		}
		else
		{
			// fallback (keeps backward compatibility)
			BioWeaponService.DeleteBioWeapon(Weapon.Id);
		}

		

		// ensure UI updates
		StateHasChanged();
	}
	// public void HandleDelete(){
	// 	BioWeaponService.DeleteBioWeapon(Weapon.Id);
	// 	StateHasChanged();
	// }
}
